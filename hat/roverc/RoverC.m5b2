{"category":"RoverC","color":"#db8c29","uiflow2":{"jscode":"const CUSTOM_ROVERC_LANGUAGES = {\n  \"CUSTOM_ROVERC_INIT\": {\n    \"en\": \"Init %1 use port %2\"\n  },\n  \"CUSTOM_ROVERC_ROVERC_MOVE\": {\n    \"en\": \"Move %1 direction %2 speed %3 duration %4 ms\"\n  },\n  \"CUSTOM_ROVERC_ROVERC_SET_SERVOS\": {\n    \"en\": \"Set Servos %1 Servo 1 %2 Servo 2 %3\"\n  },\n  \"CUSTOM_ROVERC_ROVERC_SET_MOTORS\": {\n    \"en\": \"Set Motors %1 %2 %3 %4 %5\"\n  }\n};\n\nconst initType = 'custom_roverc_init';\nBlockly.BlockRegExpList['custom_roverc'] = {\n  regexp: new RegExp(/^custom_roverc_/),\n  code: \"from RoverC import RoverC\",\n  initBlockType: initType,\n  categoryId: 'custom_roverc',\n}\nBlockly.utils.registerLanguages(CUSTOM_ROVERC_LANGUAGES)\n\nBlockly.Msg.CUSTOM_ROVERC_HUE = '#db8c29'\nBlockly.Msg.CUSTOM_ROVERC = 'RoverC'\n\nBlockly.utils.getcustom_rovercOptions = function() {\n  let options = [];\n  let list = Blockly.utils.getCustomNameList(initType);\n  for (let i = 0; i < list.length; i++) {\n    let value = list[i];\n    options.push([String(value), String(value)]);\n  }\n  if (options.length === 0) return [\n    ['roverc_0', 'roverc_0']\n  ];\n  return options;\n}\n\n\nBlockly.Blocks[\"custom_roverc_init\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_ROVERC_INIT,\n      'args0': [\n        // { 'type': 'field_dropdown', 'name': 'NAME', 'options': Blockly.utils.getcustom_rovercOptions },\n        {\n          'type': 'field_input',\n          'name': 'NAME',\n          'text': 'roverc_0'\n        },\n        {\n          \"type\": \"field_dropdown\",\n          \"name\": \"port\",\n          \"options\": [\n            [\"i2c0\", \"i2c0\"],\n            [\"i2c1\", \"i2c1\"]\n          ],\n        },\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#db8c29\",\n      \"tool\": []\n    };\n  }\n}\n\nBlockly.Python[\"custom_roverc_init\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var port = block.getFieldValue('port');\n  return `${varname} = RoverC(${port})\\n`\n}\n\nBlockly.Blocks[\"custom_roverc_roverc_move\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_ROVERC_ROVERC_MOVE,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_rovercOptions\n        },\n        {\n          \"type\": \"field_dropdown\",\n          \"name\": \"direction\",\n          \"options\": [\n            [\"Forward\", \"'forward'\"],\n            [\"Backward\", \"'backward'\"],\n            [\"Left\", \"'left'\"],\n            [\"Right\", \"'right'\"],\n            [\"Rotate Left\", \"'rotate_left'\"],\n            [\"Rotate Right\", \"'rotate_right'\"],\n            [\"Stop\", \"'stop'\"]\n          ],\n        }, {\n          'type': 'input_value',\n          'name': 'speed'\n        }, {\n          'type': 'input_value',\n          'name': 'duration'\n        },\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#db8c29\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_roverc_roverc_move\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var direction = block.getFieldValue('direction');\n  var speed = Blockly.Python.valueToCode(block, 'speed', Blockly.Python.ORDER_FUNCTION_CALL);\n  var duration = Blockly.Python.valueToCode(block, 'duration', Blockly.Python.ORDER_FUNCTION_CALL);\n  return `${varname}.RoverC_Move(${direction}, ${speed}, ${duration})\\n`\n}\n\nBlockly.Blocks[\"custom_roverc_roverc_set_servos\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_ROVERC_ROVERC_SET_SERVOS,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_rovercOptions\n        },\n        {\n          \"type\": \"input_value\",\n          \"name\": \"a1\",\n        }, {\n          \"type\": \"input_value\",\n          \"name\": \"a2\",\n        },\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#db8c29\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_roverc_roverc_set_servos\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var a1 = Blockly.Python.valueToCode(block, 'a1', Blockly.Python.ORDER_FUNCTION_CALL);\n  var a2 = Blockly.Python.valueToCode(block, 'a2', Blockly.Python.ORDER_FUNCTION_CALL);\n  return `${varname}.RoverC_Set_Servos(${a1}, ${a2})\\n`\n}\n\nBlockly.Blocks[\"custom_roverc_roverc_set_motors\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_ROVERC_ROVERC_SET_MOTORS,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_rovercOptions\n        },\n        {\n          'type': 'input_value',\n          'name': 'm1'\n        }, {\n          'type': 'input_value',\n          'name': 'm2'\n        }, {\n          'type': 'input_value',\n          'name': 'm3'\n        }, {\n          'type': 'input_value',\n          'name': 'm4'\n        },\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#db8c29\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_roverc_roverc_set_motors\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var m1 = Blockly.Python.valueToCode(block, 'm1', Blockly.Python.ORDER_FUNCTION_CALL);\n  var m2 = Blockly.Python.valueToCode(block, 'm2', Blockly.Python.ORDER_FUNCTION_CALL);\n  var m3 = Blockly.Python.valueToCode(block, 'm3', Blockly.Python.ORDER_FUNCTION_CALL);\n  var m4 = Blockly.Python.valueToCode(block, 'm4', Blockly.Python.ORDER_FUNCTION_CALL);\n  return `${varname}.RoverC_Set_Motors(${m1}, ${m2}, ${m3}, ${m4})\\n`\n}","toolbox":"\n<category name=\"RoverC\" colour=\"#db8c29\" hidden=\"true\" toolboxitemid=\"custom_roverc\">\n<title text=\"RoverC\" docsLink=\"https://github.com/D0NM/m5stack/hats/roverc\"></title>\n<block type=\"custom_roverc_init\"/><block type=\"custom_roverc_roverc_move\">\n  <value name=\"speed\">\n    <shadow type=\"math_number\">\n      <field name=\"NUM\">80</field>\n    </shadow>\n  </value>\n  <value name=\"duration\">\n    <shadow type=\"math_number\">\n      <field name=\"NUM\">0</field>\n    </shadow>\n  </value>\n</block><block type=\"custom_roverc_roverc_set_servos\">\n  <value name=\"a1\">\n    <shadow type=\"math_slider\">\n      <mutation min=\"0\" max=\"180\" step=\"1\"/>\n      <field name=\"NUM\">90</field>\n    </shadow>\n  </value>\n  <value name=\"a1\">\n    <shadow type=\"math_slider\">\n      <mutation min=\"0\" max=\"180\" step=\"1\"/>\n      <field name=\"NUM\">90</field>\n    </shadow>\n  </value>\n  <value name=\"a2\">\n    <shadow type=\"math_slider\">\n      <mutation min=\"0\" max=\"180\" step=\"1\"/>\n      <field name=\"NUM\">90</field>\n    </shadow>\n  </value>\n  <value name=\"a2\">\n    <shadow type=\"math_slider\">\n      <mutation min=\"0\" max=\"180\" step=\"1\"/>\n      <field name=\"NUM\">90</field>\n    </shadow>\n  </value>\n</block><block type=\"custom_roverc_roverc_set_motors\">\n  <value name=\"m1\">\n    <shadow type=\"math_number\">\n      <field name=\"NUM\">0</field>\n    </shadow>\n  </value>\n  <value name=\"m2\">\n    <shadow type=\"math_number\">\n      <field name=\"NUM\">0</field>\n    </shadow>\n  </value>\n  <value name=\"m3\">\n    <shadow type=\"math_number\">\n      <field name=\"NUM\">0</field>\n    </shadow>\n  </value>\n  <value name=\"m4\">\n    <shadow type=\"math_number\">\n      <field name=\"NUM\">0</field>\n    </shadow>\n  </value>\n</block>\n</category>\n","toolboxitemid":"custom_roverc","block_type":["custom_roverc___init__","custom_roverc_roverc_move","custom_roverc_roverc_set_servos","custom_roverc_roverc_set_motors"]},"data":{"name":"RoverC","note":{"en":""},"details":{"color":"#db8c29","link":"https://github.com/D0NM/m5stack/hats/roverc","image":"","category":"Custom"},"header":{"file":"RoverC","time":"2026-05-07","author":"Mikhail Bratus","email":"","license":"MIT License"},"assignments":[],"example":"","source_internal":"","source_external":"import time\nfrom hardware import I2C\nfrom roverc_pro import RoverC_Pro","members":[{"name":"__init__","note":{},"label":{"en":"Init %1 use port %2"},"params":[{"name":"port","type":null,"default":null,"note":{},"field":"dropdown","options":{"i2c0":"i2c0","i2c1":"i2c1"}}],"return":"","source":"        global rover\n        rover = RoverC_Pro(port)\n        print(\"Rover init **\")\n        print(rover.scan())","ast_return":{"code":null,"id":null},"doc_return":null},{"name":"RoverC_Move","note":{},"label":{"en":"Move %1 direction %2 speed %3 duration %4 ms"},"params":[{"name":"direction","type":null,"default":null,"note":{},"field":"dropdown","options":{"Forward":"'forward'","Backward":"'backward'","Left":"'left'","Right":"'right'","Rotate Left":"'rotate_left'","Rotate Right":"'rotate_right'","Stop":"'stop'"}},{"name":"speed","type":"int","default":"80","note":{},"field":"number","max":"100","min":"0"},{"name":"duration","type":"int","default":"0","note":{},"field":"number","max":"100","min":"0"}],"return":"","source":"        print(\"!!!*\")\n        print(\"rov move\", direction, speed, duration)\n        # global rover\n        if direction == 'forward':\n            rover.move_forward(speed)\n        elif direction == 'backward':\n            rover.move_backward(speed)\n        elif direction == 'left':\n            rover.move_left(speed)\n        elif direction == 'right':\n            rover.move_right(speed)\n        elif direction == 'rotate_left':\n            rover.rotate_left(speed)\n        elif direction == 'rotate_right':\n            rover.rotate_right(speed)\n        elif direction == 'stop':\n            rover.stop()\n\n        # Auto stop after duration (if > 0)\n        if duration > 0:\n            print(\"sleep\", duration)\n            time.sleep_ms(duration)\n            print(\"rover.stop\")\n            rover.stop()","ast_return":{"code":null,"id":null},"doc_return":null},{"name":"RoverC_Set_Servos","note":{},"label":{"en":"Set Servos %1 Servo 1 %2 Servo 2 %3"},"params":[{"name":"a1","type":"int","default":"90","note":{},"field":"slider","max":"180","min":"0","step":"1"},{"name":"a2","type":"int","default":"90","note":{},"field":"slider","max":"180","min":"0","step":"1"}],"return":"","source":"        # global rover\n        rover.set_servo_angle(a1, a2)","ast_return":{"code":null,"id":null},"doc_return":null},{"name":"RoverC_Set_Motors","note":{},"label":{"en":"Set Motors %1 %2 %3 %4 %5"},"params":[{"name":"m1","type":"int","default":"0","note":{},"field":"number","max":"100","min":"0"},{"name":"m2","type":"int","default":"0","note":{},"field":"number","max":"100","min":"0"},{"name":"m3","type":"int","default":"0","note":{},"field":"number","max":"100","min":"0"},{"name":"m4","type":"int","default":"0","note":{},"field":"number","max":"100","min":"0"}],"return":"","source":"        # global rover\n        rover.set_motor_speed(m1, m2, m3, m4)","ast_return":{"code":null,"id":null},"doc_return":null}],"python_file_name":"roverc"},"pyCode":"\n\"\"\"\nfile     RoverC\ntime     2026-05-07\nauthor   Mikhail Bratus\nemail   \nlicense  MIT License\n\"\"\"\n\nimport time\nfrom hardware import I2C\nfrom roverc_pro import RoverC_Pro\n\nclass RoverC:\n    \"\"\"\n    note:\n        en: ''\n    details:\n        color: '#db8c29'\n        link: https://github.com/D0NM/m5stack/hats/roverc\n        image: ''\n        category: Custom\n    example: ''\n    \"\"\"\n\n\n\n\n    def __init__(self, port):\n        \"\"\"\n        label:\n            en: Init %1 use port %2\n        params:\n            port:\n                name: port\n                field: dropdown\n                options:\n                    i2c0: i2c0\n                    i2c1: i2c1\n        \"\"\"\n        global rover\n        rover = RoverC_Pro(port)\n        print(\"Rover init **\")\n        print(rover.scan())\n\n    def RoverC_Move(self, direction, speed: int = 80, duration: int = 0):\n        \"\"\"\n        label:\n            en: Move %1 direction %2 speed %3 duration %4 ms\n        params:\n            direction:\n                name: direction\n                field: dropdown\n                options:\n                    Forward: '''forward'''\n                    Backward: '''backward'''\n                    Left: '''left'''\n                    Right: '''right'''\n                    Rotate Left: '''rotate_left'''\n                    Rotate Right: '''rotate_right'''\n                    Stop: '''stop'''\n            speed:\n                name: speed\n                type: int\n                default: '80'\n                field: number\n                max: '100'\n                min: '0'\n            duration:\n                name: duration\n                type: int\n                default: '0'\n                field: number\n                max: '100'\n                min: '0'\n        \"\"\"\n        print(\"!!!*\")\n        print(\"rov move\", direction, speed, duration)\n        # global rover\n        if direction == 'forward':\n            rover.move_forward(speed)\n        elif direction == 'backward':\n            rover.move_backward(speed)\n        elif direction == 'left':\n            rover.move_left(speed)\n        elif direction == 'right':\n            rover.move_right(speed)\n        elif direction == 'rotate_left':\n            rover.rotate_left(speed)\n        elif direction == 'rotate_right':\n            rover.rotate_right(speed)\n        elif direction == 'stop':\n            rover.stop()\n\n        # Auto stop after duration (if > 0)\n        if duration > 0:\n            print(\"sleep\", duration)\n            time.sleep_ms(duration)\n            print(\"rover.stop\")\n            rover.stop()\n\n    def RoverC_Set_Servos(self, a1: int = 90, a2: int = 90):\n        \"\"\"\n        label:\n            en: Set Servos %1 Servo 1 %2 Servo 2 %3\n        params:\n            a1:\n                name: a1\n                type: int\n                default: '90'\n                field: slider\n                max: '180'\n                min: '0'\n                step: '1'\n            a2:\n                name: a2\n                type: int\n                default: '90'\n                field: slider\n                max: '180'\n                min: '0'\n                step: '1'\n        \"\"\"\n        # global rover\n        rover.set_servo_angle(a1, a2)\n\n    def RoverC_Set_Motors(self, m1: int = 0, m2: int = 0, m3: int = 0, m4: int = 0):\n        \"\"\"\n        label:\n            en: Set Motors %1 %2 %3 %4 %5\n        params:\n            m1:\n                name: m1\n                type: int\n                default: '0'\n                field: number\n                max: '100'\n                min: '0'\n            m2:\n                name: m2\n                type: int\n                default: '0'\n                field: number\n                max: '100'\n                min: '0'\n            m3:\n                name: m3\n                type: int\n                default: '0'\n                field: number\n                max: '100'\n                min: '0'\n            m4:\n                name: m4\n                type: int\n                default: '0'\n                field: number\n                max: '100'\n                min: '0'\n        \"\"\"\n        # global rover\n        rover.set_motor_speed(m1, m2, m3, m4)\n\n\n","version":"alpha2"}